@model ACTI_AssetManager_Project.Models.Proyecto.ProyectoViewModel
@{
    ViewData["Title"] = "Gestión de Proyectos";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Proyecto/Proyecto.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css">
}

<div class="seccion-titulo">
    <h1>Gestión de Proyectos</h1>
</div>


<div class="resumen mb-4 d-flex gap-3">
    <div class="resumen-card">
        <span class="text-muted small uppercase fw-bold">Total de Proyectos</span>
        <h3 class="mb-0">@Model.TotalProyectos</h3>
    </div>
</div>


<div class="menu-interaccion">
    <div class="contenedor-btnCrearProyecto">
        <button type="button" class="btn btn-CrearProyecto" onclick="abrirModalProyecto()">
            <i class="bi bi-plus-circle me-2"></i> Nuevo Proyecto
        </button>
    </div>
</div>

<div class="contenedor-filtros-panel">
    <div class="filtros-panel">
        <input type="text" id="busquedaProyecto" class="filtro-input" placeholder="Buscar proyecto por nombre o descripción...">
    </div>
</div>

<div class="contenedor-pagina-proyectos">
    <div class="catalogoDeProyectos">
        <table class="tabla-premium" id="tablaProyectos">
            <thead>
                <tr>
                    <th>Nombre del Proyecto</th>
                    <th>Descripción</th>
                    <th>Último Cambio</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Proyectos)
                {
                    <tr>
                        <td class="nombre-proyecto-bold">@p.NombreProyecto.ToUpper()</td>
                        <td>
                            <span class="badge-status status-vigente">@p.Descripcion</span>
                        </td>
                        <td class="text-center text-muted">@p.FechaCambioFormateada</td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center">
                                <button class="btn-accion btn-editar-minimal"
                                        onclick="editarProyecto(@p.IdProyecto, '@p.NombreProyecto', '@p.Descripcion')">
                                    Editar
                                </button>
                                <button class="btn-accion btn-eliminar-minimal"
                                        onclick="confirmarEliminarProyecto(@p.IdProyecto)">
                                    Eliminar
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="reg-user-overlay" id="modalProyecto" style="display: none;">
    <div class="reg-user-container">
        <button type="button" class="reg-user-close-x" onclick="cerrarModalProyecto()">&times;</button>

        <h5 class="reg-user-title" id="tituloModal">Nuevo Proyecto</h5>

        <form id="formProyecto" asp-controller="Proyecto" asp-action="Registrar" method="post">
            <input type="hidden" id="idProyecto" name="IdProyecto" value="0">

            <div class="reg-user-field">
                <label class="reg-user-label">Nombre del Proyecto</label>
                <input type="text" class="reg-user-input" id="nombreProyecto" name="NombreProyecto" required placeholder="Ej. Inventario ITSON 2026">
            </div>

            <div class="reg-user-field">
                <label class="reg-user-label">Descripción</label>
                <textarea class="reg-user-input" id="descripcion" name="Descripcion" rows="3" placeholder="Breve descripción del proyecto..."></textarea>
            </div>

            <div class="reg-user-footer">
                <button type="button" class="reg-user-btn-cancel" onclick="cerrarModalProyecto()">Cancelar</button>
                <button type="submit" class="reg-user-btn-save">
                    <i class="bi bi-check-circle me-2"></i> Guardar Proyecto
                </button>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/Proyecto/Proyecto.js"></script>
}