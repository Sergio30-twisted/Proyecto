@using ACTI_AssetManager_Project.Models.Asignacion
@*Esto le dice a la vista que tipo de datos va a recibir desde el controlador*@
@model AsignacionViewModel
@{
    //Aquí se define el titulo que aparece en la pestaña del navegador
    ViewData["Title"] = "Asignación de Recursos";

    //Indica que esta pagina se va a incrustar dentro de una plantilla
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Asignacion/Modales/ModalCrearAsignacion.css" />
    <link rel="stylesheet" href="~/css/Asignacion/Asignacion.css" />
    <link rel="stylesheet" href="~/css/Asignacion/Modales/ModalinformacionResponsableAsignacion.css" />
    <link rel="stylesheet" href="~/css/Asignacion/Modales/ModalAsignarMasResponsables.css" />
    <link rel="stylesheet" href="~/css/Asignacion/Modales/ModalEliminarAsignacion.css" />
    <link rel="stylesheet" href="~/css/Asignacion/Modales/Toast-MensajesInfo.css" />
    <link rel="stylesheet" href="~/css/Asignacion/Paginado.css" />
    <link rel="stylesheet" href="~/css/Asignacion/Modales/ModalEditarAsignacion.css" />


    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css">
}

<div class="seccion-titulo">
    <h1>Asignación de Recursos</h1>
</div>


