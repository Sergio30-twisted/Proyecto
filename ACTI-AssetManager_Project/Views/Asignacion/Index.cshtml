    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script src="~/js/Acciones_Asignacion/Modales/Toast-MensajesInfo.js"></script>
    <script src="~/js/Acciones_Asignacion/Paginado.js"></script>
    <script src="~/js/Acciones_Asignacion/Modales/ModalCrearAsignacion.js"></script>
    <script src="~/js/Acciones_Asignacion/Modales/ModalinformacionResponsableAsignacion.js"></script>
    <script src="~/js/Acciones_Asignacion/Modales/ModalAsignarMasResponsables.js"></script>
    <script src="~/js/Acciones_Asignacion/Modales/ModalEliminarAsignacion.js"></script>
    <script src="~/js/Acciones_Asignacion/Modales/ModalEditarAsignacion.js"></script>
    }

